-- source: MIPStarRE/LDT/Basic/LinePolynomials.lean (elaboration context)
noncomputable instance {params : Parameters} [FieldModel params.q] :
    CoeFun (DiagonalLinePolynomial params) (fun _ => Fq params → Fq params) :=
